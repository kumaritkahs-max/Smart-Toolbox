<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_background"
    android:gravity="center">

    <TextView
        android:id="@+id/widget_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● synced"
        android:textColor="#0D1117"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:background="@drawable/widget_pill_synced" />

    <TextView
        android:id="@+id/widget_repo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="GitHub Control"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

    <Button
        android:id="@+id/widget_sync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Sync"
        android:textColor="#0D1117"
        android:textSize="11sp"
        android:minHeight="0dp"
        android:padding="6dp"
        android:background="@drawable/widget_button_bg" />
</LinearLayout>
